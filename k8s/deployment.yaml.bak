apiVersion: apps/v1
kind: Deployment
metadata:
  name: aiops-ai-agent
  namespace: aiops
  labels:
    app: aiops-ai-agent
    app.kubernetes.io/name: aiops-ai-agent
    app.kubernetes.io/part-of: aiops-kubernetes
spec:
  replicas: 2
  revisionHistoryLimit: 5
  selector:
    matchLabels:
      app: aiops-ai-agent
  template:
    metadata:
      labels:
        app: aiops-ai-agent
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8000"
        prometheus.io/path: /metrics
    spec:
      containers:
        - name: aiops-ai-agent
          image: aiops-agent:local
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8000
              name: http
          env:
            - name: HF_API_TOKEN
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: HF_API_TOKEN
            - name: HF_MODEL_ID
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: HF_MODEL_ID
            - name: FAISS_INDEX_PATH
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: FAISS_INDEX_PATH
            - name: RUNBOOKS_PATH
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: RUNBOOKS_PATH
            - name: PROMETHEUS_URL
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: PROMETHEUS_URL
            - name: GRAFANA_URL
              valueFrom:
                secretKeyRef:
                  name: aiops-platform-secrets
                  key: GRAFANA_URL
          resources:
            requests:
              cpu: 200m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 20
            periodSeconds: 10
            timeoutSeconds: 2
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 10
            periodSeconds: 5
            timeoutSeconds: 2
            failureThreshold: 3
